# Database
DATABASE_URL="mysql://pasdisaku_user:CHANGE_ME@localhost:3306/pasdisaku"

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Encryption for stored supplier/woocommerce credentials (32 bytes hex)
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# App
PORT=3001
NODE_ENV=production

# WooCommerce (default store, opsional - bisa juga dikelola per-row di DB)
WC_STORE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# WhatsApp Business Cloud API (resmi, Meta)
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
